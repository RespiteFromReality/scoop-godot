    "version": "4.7-beta3",
    "description": "A feature-packed, cross-platform game engine to create 2D and 3D games from a unified interface.",
    "homepage": "https://godotengine.org/",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/godotengine/godot-builds/releases/download/4.7-beta3/Godot_v4.7-beta3_mono_win64.zip",
            "hash": "sha512:c76c7e67e49b2f73e86892d9f032a9440567d76b5076910208aab283041913f6f810714ad0856b5ac3cb434081c5d1102cdeff0599e198f9c52cdcd3c1b601bb",
            "extract_dir": "Godot_v4.7-beta3_mono_win64"
        },
        "32bit": {
            "url": "https://github.com/godotengine/godot-builds/releases/download/4.7-beta3/Godot_v4.7-beta3_mono_win32.zip",
            "hash": "sha512:ba2409f749498e36549a56e35e8341b5a170e39c5e6a6aa6b31c7d95ed531cbbf81953c57f753c39a31230390ecb89f0c462ba4dce1607fb0da4b19bc102e6bc",
            "extract_dir": "Godot_v4.7-beta3_mono_win32"
        }
    },
    "pre_install": [
        "Remove-Item \"$dir\\Godot_*_console.*\"",
        "Get-Item \"$dir\\Godot_*.exe\" | Rename-Item -NewName 'godot-mono.exe'"
    ],
    "bin": "godot-mono.exe",
    "shortcuts": [
        [
            "godot-mono.exe",
            "Godot Engine (Mono)"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/godotengine/godot-builds/releases",
        "jsonpath": "$[*].tag_name",
        "regex": "(?<ver>[\\d.]+)-beta(?<beta>[\\d.]+)",
        "replace": "${1}-beta${2}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/godotengine/godot-builds/releases/download/$version/Godot_v$version_mono_win64.zip",
                "extract_dir": "Godot_v$version_mono_win64"
            },
            "32bit": {
                "url": "https://github.com/godotengine/godot-builds/releases/download/$version/Godot_v$version_mono_win32.zip",
                "extract_dir": "Godot_v$version_mono_win32"
            }
        },
        "hash": {
            "url": "$baseurl/SHA512-SUMS.txt"
        }
    }
}
