{
    "version": "4.7-beta2",
    "description": "A feature-packed, cross-platform game engine to create 2D and 3D games from a unified interface.",
    "homepage": "https://godotengine.org/",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/godotengine/godot-builds/releases/download/4.7-beta2/Godot_v4.7-beta2_mono_win64.zip",
            "hash": "sha512:9f1edead03bf66f4945110a7941cad86cb4a7464496b37a0e5074073561381dc3c1f6bf5e41b75ec7fc353873bbf45bf4565e82f4bdebdd5c1f7977b79938602",
            "extract_dir": "Godot_v4.7-beta2_mono_win64"
        },
        "32bit": {
            "url": "https://github.com/godotengine/godot-builds/releases/download/4.7-beta2/Godot_v4.7-beta2_mono_win32.zip",
            "hash": "sha512:542061fad4d1e3803e4f7925d3af4b2609a6391057d9a08650d3882c184cd917f2f19a31af84bbcc04308efc8dc1430b884337026f326587f0fff517bf38b341",
            "extract_dir": "Godot_v4.7-beta2_mono_win32"
        }
    },
    "pre_install": [
        "Remove-Item \"$dir\\Godot_*_console.*\"",
        "Get-Item \"$dir\\Godot_*.exe\" | Rename-Item -NewName 'godot-mono.exe'"
    ],
    "bin": "godot-mono.exe",
    "shortcuts": [
        [
            "godot-mono.exe",
            "Godot Engine (Mono)"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/godotengine/godot-builds/releases",
        "jsonpath": "$[*].tag_name",
        "regex": "(?<ver>[\\d.]+)-beta(?<beta>[\\d.]+)",
        "replace": "${1}-beta${2}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/godotengine/godot-builds/releases/download/$version/Godot_v$version_mono_win64.zip",
                "extract_dir": "Godot_v$version_mono_win64"
            },
            "32bit": {
                "url": "https://github.com/godotengine/godot-builds/releases/download/$version/Godot_v$version_mono_win32.zip",
                "extract_dir": "Godot_v$version_mono_win32"
            }
        },
        "hash": {
            "url": "$baseurl/SHA512-SUMS.txt"
        }
    }
}
